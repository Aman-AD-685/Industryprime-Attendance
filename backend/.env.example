SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Required for auth/JWT validation:
SUPABASE_ANON_KEY=

# FastAPI runs with CORS already configured for Next.js dev.
# Production frontend URL, e.g. https://your-app.vercel.app
FRONTEND_URL=
# Or comma-separated origins, e.g. https://a.vercel.app,https://b.vercel.app
CORS_ORIGINS=

# Default API port for local Next.js integration. Match web/.env.local NEXT_PUBLIC_API_URL.
API_PORT=8000

# Required for FastAPI-issued JWTs. Use a long random value in production.
JWT_SECRET=
#
# Start API (recommended): from `backend/` run  `python main.py`
# Or: `uvicorn main:app --reload --host 127.0.0.1 --port 8000`
# Or: `.\run.ps1`
